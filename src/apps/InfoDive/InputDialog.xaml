<Window x:Class="InfoDive.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="入力" Width="360" Height="160"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{StaticResource Bg1}">
    <StackPanel Margin="20">
        <TextBlock x:Name="PromptText" FontSize="13" FontWeight="SemiBold"
                   Foreground="{StaticResource Text1}" Margin="0,0,0,10"/>
        <TextBox x:Name="InputBox" FontSize="13" Padding="6,4"
                 BorderBrush="{StaticResource Border1}" KeyDown="InputBox_KeyDown"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="キャンセル" Style="{StaticResource GhostButton}"
                    Click="Cancel_Click" Margin="0,0,8,0" Width="80"/>
            <Button Content="OK" Style="{StaticResource AccentButton}"
                    Click="OK_Click" Width="80"/>
        </StackPanel>
    </StackPanel>
</Window>
